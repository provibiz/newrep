---
export const prerender = true;

import { createReader } from "@keystatic/core/reader";
import Markdoc from "@markdoc/markdoc";
import keystaticConfig from "../../keystatic.config";

const reader = createReader(process.cwd(), keystaticConfig);

const startseite = await reader.singletons.startseite.read();
if (!startseite) {
  throw new Error(
    'Singleton "Startseite" wurde nicht gefunden. Bitte unter /keystatic anlegen.'
  );
}

const { node: ueberUnsNode } = await startseite.ueber_uns_text();
const ueberUnsHtml = Markdoc.renderers.html(Markdoc.transform(ueberUnsNode));

const phoneNumber = startseite.telefonnummer;
const phoneHref = `tel:${phoneNumber.replace(/[^\d+]/g, "")}`;
const whatsappHref = `https://wa.me/${phoneNumber.replace(/[^\d]/g, "")}`;
const email = startseite.email;

const headlineParts = startseite.hero_headline.split(". ").filter(Boolean);
const headlineFirst = headlineParts[0] ?? startseite.hero_headline;
const headlineRest = headlineParts.slice(1).join(". ");

const leistungenSlugs = await reader.collections.leistungen.list();
const leistungenEntries = await Promise.all(
  leistungenSlugs.map((slug) => reader.collections.leistungen.read(slug))
);
const services = leistungenEntries
  .map((entry) => ({
    title: entry!.titel,
    description: entry!.kurzbeschreibung,
    icon: entry!.icon_name,
    reihenfolge: entry!.reihenfolge ?? 0,
  }))
  .sort((a, b) => a.reihenfolge - b.reihenfolge);

const stats = [
  { value: "15+", label: "Jahre Erfahrung" },
  { value: "100%", label: "geschult & versichert" },
  { value: "24h", label: "Antwortzeit" },
];

const whyUs = [
  {
    number: "01",
    title: "Geschult & versichert",
    description: "Unser gesamtes Team ist vollständig geschult, versichert und arbeitet mit modernsten Techniken.",
  },
  {
    number: "02",
    title: "Umweltfreundlich",
    description: "Wir verwenden ausschließlich umweltverträgliche Reinigungsmittel – sicher für Sie, Ihre Mitarbeiter und die Natur.",
  },
  {
    number: "03",
    title: "Flexibel & individuell",
    description: "Wöchentliche, zweiwöchentliche oder einmalige Reinigungspläne, die zu Ihrem Alltag passen.",
  },
  {
    number: "04",
    title: "Faire Preise",
    description: "Hochwertige Dienstleistungen zu transparenten, erschwinglichen Konditionen.",
  },
];

const steps = [
  {
    number: "1",
    title: "Erstkontakt",
    description: "Erreichen Sie uns telefonisch oder per Mail. Bei speziellen Wünschen kommen wir gerne kostenlos vor Ort.",
  },
  {
    number: "2",
    title: "Angebot",
    description: "Nach Prüfung Ihrer Wünsche erhalten Sie innerhalb eines Tages ein unverbindliches Angebot.",
  },
  {
    number: "3",
    title: "Ausführung",
    description: "Termin vereinbart – unser Fachpersonal kommt vorbei und los geht's.",
  },
];

const tags = [
  "Badezimmer", "Balkon & Terrasse", "Bodenpflege", "Dachrinnen", "Desinfektion",
  "Fenster", "Fassadenreinigung", "Garten- & Rasenpflege", "Glasflächen", "Hausreinigung",
  "Jalousien", "Küchen", "Müllentsorgung", "Nasswischen", "Polsterreinigung",
  "Schaufenster", "Staubsaugen", "Staubwischen", "Teppichreinigung", "Tiefenreinigung",
  "Toiletten", "Treppenhaus",
];

const icons: Record<string, string> = {
  shield:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 5v6c0 5 4 9 8 11 4-2 8-6 8-11V5l-8-3z"/><path d="m9 12 2 2 4-4"/></svg>',
  pin:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-6.4-7-12a7 7 0 1 1 14 0c0 5.6-7 12-7 12z"/><circle cx="12" cy="9" r="2.5"/></svg>',
  users:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"/><circle cx="10" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
  clock:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>',
  sparkle:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v4M12 17v4M3 12h4M17 12h4M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M18.4 5.6l-2.8 2.8M8.4 15.6l-2.8 2.8"/></svg>',
  broom:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 4 9 14"/><path d="m13 18-4 4-6-6 4-4z"/><path d="M9 14 4 19l-1 1"/><path d="M19 4a2.5 2.5 0 0 1 0 5"/></svg>',
  building:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="1"/><path d="M9 22v-4h6v4M8 6h.01M12 6h.01M16 6h.01M8 10h.01M12 10h.01M16 10h.01M8 14h.01M12 14h.01M16 14h.01"/></svg>',
  window:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M12 3v18M3 12h18"/></svg>',
  key:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="15.5" r="4.5"/><path d="m10.5 12.5 8-8M16 6l2 2M19 3l2 2"/></svg>',
  stairs:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21v-4h4v-4h4v-4h4V5h4"/></svg>',
  school:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3 9 4.5-9 4.5-9-4.5L12 3z"/><path d="M7 10.5V16c0 1 2.5 2.5 5 2.5s5-1.5 5-2.5v-5.5"/></svg>',
  medical:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M12 8v8M8 12h8"/></svg>',
  whatsapp:
    '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.6-.8-1.9-.9-.2-.1-.4-.1-.6.1-.2.2-.6.9-.8 1.1-.1.2-.3.2-.5.1-1.3-.6-2.1-1.1-3-2.5-.2-.3 0-.5.1-.6.2-.2.4-.5.6-.7.1-.2.1-.4 0-.6-.1-.2-.6-1.5-.8-2-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.4-.2.3-.9 1-.9 2.3 0 1.4 1 2.7 1.1 2.9.1.2 1.9 3 4.6 4 2.7 1.1 2.7.7 3.2.6.5 0 1.6-.6 1.8-1.3.2-.6.2-1.1.2-1.2-.1-.2-.2-.2-.5-.3z"/><path d="M12 2a10 10 0 0 0-8.6 15L2 22l5.2-1.4A10 10 0 1 0 12 2z"/></svg>',
  arrow:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>',
};

function iconSvg(name: string): string {
  return icons[name] ?? "";
}
---

<html lang="de">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{startseite.meta_title}</title>
		<meta name="description" content={startseite.meta_description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;700;800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<header class="site-header">
			<nav class="navbar">
				<a href="#top" class="logo">
					<span class="logo-main">GSO</span>
					<span class="logo-sub">Gebäude-Service<br /><small>Konstanz &middot; Bodensee</small></span>
				</a>

				<input type="checkbox" id="nav-toggle" class="nav-toggle" />
				<label for="nav-toggle" class="nav-toggle-label" aria-label="Menü öffnen">
					<span></span>
					<span></span>
					<span></span>
				</label>

				<div class="nav-links">
					<a href="#top">Start</a>
					<a href="#leistungen">Leistungen</a>
					<a href="#ueber-uns">Über uns</a>
					<a href="#kontakt">Kontakt</a>
					<a href={phoneHref} class="nav-phone">
						<span set:html={iconSvg("clock")} class="nav-phone-icon" />
						{phoneNumber}
					</a>
				</div>
			</nav>
		</header>

		<main id="top">
			<!-- HERO -->
			<section class="hero">
				<div class="hero-inner">
					<div class="hero-text">
						<span class="badge">
							<span class="badge-icon" set:html={iconSvg("pin")} />
							Region Konstanz &middot; Bodensee
						</span>
						<h1>
							{headlineFirst}
							{headlineRest && (
								<>
									<br />
									<span class="text-mint">{headlineRest}</span>
								</>
							)}
						</h1>
						<p class="hero-sub">{startseite.hero_subline}</p>
						<div class="hero-cta">
							<a href="#kontakt" class="btn btn-primary">{startseite.hero_cta_primaer}</a>
							<a href="#leistungen" class="btn btn-outline">{startseite.hero_cta_sekundaer}</a>
						</div>
						<ul class="stats">
							{stats.map((stat) => (
								<li>
									<span class="stat-value">{stat.value}</span>
									<span class="stat-label">{stat.label}</span>
								</li>
							))}
						</ul>
					</div>
					<div class="hero-visual" aria-hidden="true"></div>
				</div>
			</section>

			<!-- LEISTUNGEN -->
			<section id="leistungen" class="services">
				<div class="section-inner">
					<p class="eyebrow">Unsere Leistungen</p>
					<h2>Reinigung für jeden Bedarf</h2>
					<p class="section-sub">
						Von der intensiven Grundreinigung bis zur regelmäßigen Pflege Ihrer Räume –
						wir bieten maßgeschneiderte Lösungen für Ihr Zuhause, Büro oder Gewerbeobjekt.
					</p>
					<div class="service-grid">
						{services.map((service) => (
							<article class="service-card">
								<span class="service-icon" set:html={iconSvg(service.icon)} />
								<h3>{service.title}</h3>
								<p>{service.description}</p>
								<a href="#kontakt" class="service-link">
									Mehr erfahren
									<span class="link-arrow" set:html={iconSvg("arrow")} />
								</a>
							</article>
						))}
					</div>
				</div>
			</section>

			<!-- WARUM GSO -->
			<section id="ueber-uns" class="why-us">
				<div class="section-inner">
					<p class="eyebrow">Warum GSO</p>
					<h2>Sauberkeit, auf die Sie sich verlassen können</h2>
					<div class="section-sub" set:html={ueberUnsHtml} />
					<div class="why-grid">
						{whyUs.map((item) => (
							<div class="why-card">
								<span class="why-number">{item.number}</span>
								<h3>{item.title}</h3>
								<p>{item.description}</p>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- PROZESS -->
			<section class="process">
				<div class="section-inner">
					<p class="eyebrow">So einfach geht's</p>
					<h2>In drei Schritten zur sauberen Lösung</h2>
					<div class="process-grid">
						{steps.map((step) => (
							<div class="process-card">
								<span class="process-number">{step.number}</span>
								<h3>{step.title}</h3>
								<p>{step.description}</p>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- TAG CLOUD -->
			<section class="tag-cloud-section">
				<div class="section-inner">
					<p class="eyebrow">Schwerpunkte</p>
					<h2>Was wir alles reinigen</h2>
					<p class="section-sub">
						Ein Auszug aus unserem Leistungsspektrum – sprechen Sie uns gerne auf
						individuelle Anforderungen an.
					</p>
					<ul class="tag-cloud">
						{tags.map((tag) => (
							<li class="tag">{tag}</li>
						))}
					</ul>
				</div>
			</section>

			<!-- CTA SECTION -->
			<section class="cta-section">
				<div class="section-inner cta-inner">
					<div class="cta-text">
						<h2>Bereit für strahlend saubere Räume?</h2>
						<p>
							Holen Sie sich Ihr kostenloses, unverbindliches Angebot – wir melden uns
							innerhalb von 24 Stunden.
						</p>
					</div>
					<div class="cta-buttons">
						<a href="#kontakt" class="btn btn-light">Angebot anfragen</a>
						<a href={whatsappHref} class="btn btn-whatsapp">
							<span class="btn-icon" set:html={iconSvg("whatsapp")} />
							WhatsApp
						</a>
					</div>
				</div>
			</section>
		</main>

		<footer id="kontakt" class="site-footer">
			<div class="section-inner footer-inner">
				<div class="footer-col">
					<h3 class="footer-logo">GSO Gebäude-Service</h3>
					<p>
						Professionelle Gebäudereinigung in Konstanz und am Bodensee. Gründlich,
						zuverlässig und preiswert – bei Ihnen zuhause oder im Büro.
					</p>
				</div>
				<div class="footer-col">
					<h3>Leistungen</h3>
					{services.map((service) => (
						<p><a href="#leistungen">{service.title}</a></p>
					))}
				</div>
				<div class="footer-col">
					<h3>Unternehmen</h3>
					<p><a href="#ueber-uns">Über uns</a></p>
					<p><a href="#kontakt">Kontakt</a></p>
					<p><a href="#leistungen">Alle Leistungen</a></p>
				</div>
				<div class="footer-col">
					<h3>Kontakt</h3>
					<p><a href={phoneHref}>{phoneNumber}</a></p>
					<p><a href={`mailto:${email}`}>{email}</a></p>
					<p><a href={whatsappHref}>WhatsApp Chat</a></p>
					<p>{startseite.adresse}</p>
				</div>
			</div>
			<div class="footer-bottom">
				<p>
					&copy; {new Date().getFullYear()} GSO Gebäude-Service &middot; Konstanz &middot;
					Alle Rechte vorbehalten &middot; <a href="#">Datenschutz</a> &middot;
					<a href="#">Impressum</a>
				</p>
			</div>
		</footer>
	</body>
</html>

<style>
	:root {
		--color-navy: #0f2044;
		--color-navy-light: #1a2f5c;
		--color-orange: #e85d04;
		--color-mint: #14b8a6;
		--color-mint-light: #ecfdf9;
		--color-whatsapp: #25d366;
		--color-bg-light: #f4f6f8;
		--color-white: #ffffff;
		--font-main: "Plus Jakarta Sans", sans-serif;
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		font-family: var(--font-main);
		font-weight: 400;
		color: var(--color-navy);
		background: var(--color-white);
		line-height: 1.6;
	}

	h1,
	h2,
	h3 {
		font-weight: 800;
		line-height: 1.2;
		color: var(--color-navy);
	}

	a {
		text-decoration: none;
		color: inherit;
	}

	ul {
		list-style: none;
	}

	.section-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 4rem 1.5rem;
	}

	.eyebrow {
		color: var(--color-mint);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-size: 0.85rem;
		text-align: center;
		margin-bottom: 0.75rem;
	}

	.section-sub {
		text-align: center;
		max-width: 640px;
		margin: 0 auto 3rem;
		color: #3c4a63;
	}

	.text-mint {
		color: var(--color-mint);
	}

	/* Buttons */
	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 0.9rem 1.8rem;
		border-radius: 999px;
		font-weight: 700;
		font-size: 1rem;
		transition: transform 0.15s ease, opacity 0.15s ease;
		text-align: center;
	}

	.btn:hover {
		transform: translateY(-2px);
		opacity: 0.92;
	}

	.btn-icon,
	.link-arrow {
		display: inline-flex;
	}

	.btn-icon :global(svg),
	.link-arrow :global(svg) {
		width: 18px;
		height: 18px;
	}

	.btn-primary {
		background: var(--color-orange);
		color: var(--color-white);
	}

	.btn-outline {
		background: transparent;
		border: 2px solid var(--color-navy);
		color: var(--color-navy);
	}

	.btn-light {
		background: var(--color-white);
		color: var(--color-navy);
	}

	.btn-whatsapp {
		background: var(--color-whatsapp);
		color: var(--color-white);
	}

	/* Header / Nav */
	.site-header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: var(--color-white);
		border-bottom: 1px solid #e3e7ec;
	}

	.navbar {
		max-width: 1200px;
		margin: 0 auto;
		padding: 1rem 1.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		position: relative;
	}

	.logo {
		display: flex;
		align-items: baseline;
		gap: 0.5rem;
	}

	.logo-main {
		font-weight: 800;
		font-size: 1.5rem;
		color: var(--color-navy);
	}

	.logo-sub {
		font-weight: 700;
		font-size: 0.85rem;
		color: var(--color-navy);
		line-height: 1.2;
	}

	.logo-sub small {
		font-weight: 500;
		font-size: 0.65rem;
		color: var(--color-mint);
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}

	.nav-toggle {
		display: none;
	}

	.nav-toggle-label {
		display: none;
		flex-direction: column;
		gap: 5px;
		cursor: pointer;
		z-index: 110;
	}

	.nav-toggle-label span {
		width: 26px;
		height: 3px;
		background: var(--color-navy);
		border-radius: 2px;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 2rem;
		font-weight: 500;
	}

	.nav-links a {
		color: var(--color-navy);
		transition: color 0.15s ease;
	}

	.nav-links a:hover {
		color: var(--color-mint);
	}

	.nav-phone {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		background: var(--color-navy);
		color: var(--color-white) !important;
		font-weight: 700;
		padding: 0.6rem 1.2rem;
		border-radius: 999px;
	}

	.nav-phone:hover {
		color: var(--color-white) !important;
		opacity: 0.9;
	}

	.nav-phone-icon :global(svg) {
		width: 16px;
		height: 16px;
	}

	/* Hero */
	.hero {
		background: linear-gradient(160deg, #ffffff 0%, var(--color-mint-light) 100%);
	}

	.hero-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 3rem 1.5rem 4rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem;
		align-items: center;
		width: 100%;
	}

	.badge {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		background: var(--color-mint-light);
		color: var(--color-mint);
		font-weight: 700;
		font-size: 0.8rem;
		padding: 0.4rem 1rem;
		border-radius: 999px;
		margin-bottom: 1.25rem;
	}

	.badge-icon :global(svg) {
		width: 14px;
		height: 14px;
	}

	.hero-text h1 {
		font-size: 2.25rem;
		margin-bottom: 1.25rem;
	}

	.hero-sub {
		font-size: 1.1rem;
		font-weight: 400;
		color: #3c4a63;
		margin-bottom: 2rem;
		max-width: 540px;
	}

	.hero-cta {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		margin-bottom: 2.5rem;
	}

	.stats {
